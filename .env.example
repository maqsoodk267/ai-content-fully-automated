# Application Settings
APP_NAME=AI Content Automation Platform
DEBUG=False
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/content_db
SQLALCHEMY_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_EXPIRY=3600

# MinIO Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_BUCKET=content-assets

# Vector Database
VECTOR_DB_TYPE=chroma  # 'chroma' or 'qdrant'
CHROMA_HOST=localhost
CHROMA_PORT=8000
QDRANT_URL=http://localhost:6333

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=mistral  # or llama

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT / Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Keys (Social Media Platforms)
# YouTube Analytics API
YOUTUBE_API_KEY=your-youtube-api-key-here

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token-here
INSTAGRAM_APP_ID=your-instagram-app-id-here
INSTAGRAM_APP_SECRET=your-instagram-app-secret-here

# TikTok Marketing API
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token-here
TIKTOK_APP_ID=your-tiktok-app-id-here
TIKTOK_APP_SECRET=your-tiktok-app-secret-here

# Facebook Graph API
FACEBOOK_PAGE_ACCESS_TOKEN=your-facebook-page-access-token-here
FACEBOOK_APP_ID=your-facebook-app-id-here
FACEBOOK_APP_SECRET=your-facebook-app-secret-here

# Twitter/X API v2
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_BEARER_TOKEN=your-x-bearer-token
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret

# LinkedIn Marketing API
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token-here
LINKEDIN_CLIENT_ID=your-linkedin-client-id-here
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret-here

# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Google Trends
GOOGLE_TRENDS_ENABLED=True

# External Services
GOOGLE_TRANSLATE_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Translation Services
LIBRETRANSLATE_URL=http://localhost:5000
HUGGINGFACE_API_URL=https://api-inference.huggingface.co
HUGGINGFACE_API_TOKEN=your-huggingface-api-token
TRANSLATION_CACHE_TTL_S=86400
TRANSLATION_TIMEOUT_LIBRE_S=10.0
TRANSLATION_TIMEOUT_HF_S=30.0
TRANSLATION_MODEL_CACHE_PATH=/path/to/translation/models/cache

# File Upload Settings
MAX_UPLOAD_SIZE=104857600  # 100MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,mp4,mov,avi,mkv

# Performance
WORKERS_COUNT=4
TASK_MAX_RETRIES=3
TASK_TIMEOUT=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring
PROMETHEUS_ENABLED=True
GRAFANA_URL=http://localhost:3000
